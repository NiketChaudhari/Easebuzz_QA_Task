    {
      "name": "Add Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"To check status code for POST is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"To check response title for POST\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    var title_exp = pm.variables.get(\"Post_title\"); \r",
              "    pm.expect(jsonData.title).to.eql(title_exp);\r",
              "});\r",
              "\r",
              "pm.test(\"To check response body for POST\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    var body_exp = pm.variables.get(\"Post_body\"); \r",
              "    pm.expect(jsonData.body).to.eql(body_exp);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
